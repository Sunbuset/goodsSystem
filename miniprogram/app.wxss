page {
  background:
    radial-gradient(circle at 14% 2%, #ffedd5 0, #fff7ed 26%, transparent 27%),
    radial-gradient(circle at 88% 7%, #ccfbf1 0, #ecfeff 30%, transparent 31%),
    #f8fafc;
  color: #0f172a;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.card {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.muted {
  color: #64748b;
}

button {
  border-radius: 999rpx;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.btn-primary {
  background: linear-gradient(120deg, #ea580c, #f97316);
  color: #ffffff;
  border-radius: 999rpx;
  margin-top: 16rpx;
  box-shadow: 0 12rpx 24rpx rgba(249, 115, 22, 0.28);
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.86);
  color: #0f766e;
  border: 1rpx solid #14b8a6;
  border-radius: 999rpx;
}