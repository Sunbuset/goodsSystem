.detail-cover {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.14);
}

.price-line {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.detail-content {
  color: #334155;
  line-height: 1.8;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 18rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-row button {
  flex: 1;
}

.price {
  color: #c2410c;
  font-weight: 700;
}