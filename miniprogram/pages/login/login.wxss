.login-page {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 80rpx;
}

.login-card {
  width: 100%;
  text-align: center;
  background: rgba(255, 255, 255, 0.92);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
  color: #0f172a;
}

.name-input {
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 999rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 24rpx;
  text-align: left;
}

.btn-secondary {
  margin-top: 20rpx;
  background: #ffffff;
  color: #0f766e;
  border: 1rpx solid #14b8a6;
}