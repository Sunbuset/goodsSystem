.login-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-card {
  width: 100%;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  color: #111827;
}

.name-input {
  background: #f3f4f6;
  border-radius: 999rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 24rpx;
  text-align: left;
}

.btn-secondary {
  margin-top: 20rpx;
  background: transparent;
  color: #1677ff;
  border: 1rpx solid #dbeafe;
}