.order-item {
  padding: 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  margin-top: 14rpx;
  background: #ffffff;
}

.order-item:first-of-type {
  margin-top: 0;
}

.order-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.status {
  color: #0f766e;
  background: #f0fdfa;
  border: 1rpx solid #99f6e4;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.empty-tip {
  text-align: center;
  padding: 32rpx 0;
}