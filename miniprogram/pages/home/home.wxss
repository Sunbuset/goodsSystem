.banner {
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.12);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.category-item {
  padding: 14rpx 22rpx;
  background: linear-gradient(120deg, #ecfeff, #f0fdfa);
  color: #0f766e;
  border: 1rpx solid #99f6e4;
  border-radius: 999rpx;
}

.goods-item {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e2e8f0;
}

.goods-item:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.goods-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
}

.price {
  color: #c2410c;
  font-weight: 700;
}